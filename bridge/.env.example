# Port the bridge listens on (default: 3131)
PORT=3131

# Default project path the bridge runs Claude against when the request omits one
PROJECT_PATH=/path/to/your/project

# Optional: explicit path to the Claude Code binary.
# Leave unset to let the Agent SDK auto-detect its bundled binary in node_modules.
# Use this only if the bundled binary cannot be found.
# CLAUDE_PATH=/Users/you/.local/bin/claude
